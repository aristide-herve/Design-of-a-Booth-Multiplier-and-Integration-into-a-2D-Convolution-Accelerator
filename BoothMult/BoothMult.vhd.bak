## Fichier: b_transformer.vhd

```vhdl
-- b_transformer.vhd
-- Transformer de B : produit simultanément M0..M4 (17 bits)
library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity b_transformer is
    port (
        B  : in  std_logic_vector(15 downto 0);
        M0 : out std_logic_vector(16 downto 0); -- 0
        M1 : out std_logic_vector(16 downto 0); -- +B
        M2 : out std_logic_vector(16 downto 0); -- -B
        M3 : out std_logic_vector(16 downto 0); -- +2B
        M4 : out std_logic_vector(16 downto 0)  -- -2B
    );
end entity b_transformer;

architecture rtl of b_transformer is
    signal B_s   : signed(15 downto 0);
    signal B_ext : signed(16 downto 0);
    signal B2    : signed(16 downto 0);
begin
    B_s <= signed(B);
    B_ext <= resize(B_s, 17);
    B2 <= shift_left(B_ext, 1);

    -- M0 = 0
    M0 <= (others => '0');

    -- +B
    M1 <= std_logic_vector(B_ext);

    -- -B
    M2 <= std_logic_vector(-B_ext);

    -- +2B
    M3 <= std_logic_vector(B2);

    -- -2B
    M4 <= std_logic_vector(-B2);
end architecture rtl;
```

