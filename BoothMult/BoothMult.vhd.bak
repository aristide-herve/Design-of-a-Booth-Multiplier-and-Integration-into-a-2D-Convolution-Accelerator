## Fichier: mux5.vhd

```vhdl
-- mux5.vhd
-- Multiplexeur 5 entrées (17 bits) contrôlé par sel (3 bits, option A : 0..4)
library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity mux5 is
    port (
        M0  : in  std_logic_vector(16 downto 0);
        M1  : in  std_logic_vector(16 downto 0);
        M2  : in  std_logic_vector(16 downto 0);
        M3  : in  std_logic_vector(16 downto 0);
        M4  : in  std_logic_vector(16 downto 0);
        sel : in  std_logic_vector(2 downto 0);
        P   : out std_logic_vector(16 downto 0)
    );
end entity mux5;

architecture rtl of mux5 is
begin
    process(M0,M1,M2,M3,M4,sel)
    begin
        case sel is
            when "000" => P <= M0; -- 0
            when "001" => P <= M1; -- +B
            when "010" => P <= M2; -- -B
            when "011" => P <= M3; -- +2B
            when "100" => P <= M4; -- -2B
            when others => P <= (others => '0');
        end case;
    end process;
end architecture rtl;
```

