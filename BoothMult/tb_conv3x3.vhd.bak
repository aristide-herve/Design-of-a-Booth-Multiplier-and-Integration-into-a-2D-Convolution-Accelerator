library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity tb_conv3x3 is
end entity;

architecture sim of tb_conv3x3 is

    constant WIDTH  : integer := 5;   -- image 5×5
    constant HEIGHT : integer := 5;

    -- DUT signals
    signal clk       : std_logic := '0';
    signal rst       : std_logic := '1';
    signal pixel_in  : std_logic_vector(15 downto 0) := (others => '0');
    signal pixel_win : std_logic_vector(143 downto 0);
    signal valid_out : std_logic;
    signal Qout      : std_logic_vector(31 downto 0);

    -- Image 5×5 (16 bits signed)
    type img_type is array(0 to HEIGHT-1, 0 to WIDTH-1) of std_logic_vector(15 downto 0);

    constant IMG : img_type := (
        (x"0001", x"0002", x"0003", x"0004", x"0005"),
        (x"0006", x"0007", x"0008", x"0009", x"000A"),
        (x"000B", x"000C", x"000D", x"000E", x"000F"),
        (x"0010", x"0011", x"0012", x"0013", x"0014"),
        (x"0015", x"0016", x"0017", x"0018", x"0019")
    );

    -- Kernel Sobel simple (exemple)
    constant K00 : std_logic_vector(15 downto 0) := x"FFFF"; -- -1
    constant K01 : std_logic_vector(15 downto 0) := x"0000";
    constant K02 : std_logic_vector(15 downto 0) := x"0001"; -- +1

    constant K10 : std_logic_vector(15 downto 0) := x"FFFE"; -- -2
    constant K11 : std_logic_vector(15 downto 0) := x"0000";
    constant K12 : std_logic_vector(15 downto 0) := x"0002"; -- +2

    constant K20 : std_logic_vector(15 downto 0) := x"FFFF"; -- -1
    constant K21 : std_logic_vector(15 downto 0) := x"0000";
    constant K22 : std_logic_vector(15 downto 0) := x"0001"; -- +1

begin

    ---------------------------------------------------------------------
    -- Clock
    ---------------------------------------------------------------------
    clk <= not clk after 5 ns;

    ---------------------------------------------------------------------
    -- DUT: line buffer + conv3x3
    ---------------------------------------------------------------------
    LB: entity work.line_buffer_3lines_simple
        generic map (WIDTH => WIDTH)
        port map(
            clk       => clk,
            rst       => rst,
            pixel_in  => pixel_in,
            pixel_out => pixel_win,
            valid_out => valid_out
        );

    CV: entity work.conv3x3_from_window
        port map(
            pixel_win => pixel_win,
            k00 => K00, k01 => K01, k02 => K02,
            k10 => K10, k11 => K11, k12 => K12,
            k20 => K20, k21 => K21, k22 => K22,
            Qout => Qout
        );


    ---------------------------------------------------------------------
    -- Stimulus
    ---------------------------------------------------------------------
    process
    begin
        -- Reset
        rst <= '1';
        wait for 20 ns;
        rst <= '0';

        -- Envoi de l’image pixel par pixel
        for y in 0 to HEIGHT-1 loop
            for x in 0 to WIDTH-1 loop
                pixel_in <= IMG(y, x);
                wait for 10 ns; -- 1 cycle
            end loop;
        end loop;

        -- Fin simulation
        wait for 100 ns;
        assert false report "END OF SIMULATION" severity failure;
    end process;

    ---------------------------------------------------------------------
    -- Debug affichage
    ---------------------------------------------------------------------
    process(clk)
    begin
        if rising_edge(clk) then
            if valid_out = '1' then
                report "3x3 Window valid - Qout = " &
                       integer'image(to_integer(signed(Qout)));
            end if;
        end if;
    end process;

end architecture sim;
