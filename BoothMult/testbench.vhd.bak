library IEEE;
use IEEE.std_logic;
use IEEE.numeric_std;

entity testbench is
end entity;

architecture behavioral of testbench is
    component windowing_module is
        port (
            clk : in std_logic;
            rst : in std_logic;
            image_data : in signed(15 downto 0);
            pixel_window : out signed(143 downto 0);
            kernel_constants : out signed(143 downto 0)
        );
    end component;

    signal clk : std_logic := '0';
    signal rst : std_logic := '1';
    signal image_data : signed(15 downto 0) := (others => '0');
    signal pixel_window : signed(143 downto 0) := (others => '0');
    signal kernel_constants : signed(143 downto 0) := (others => '0');

    file image_file : text open "image.txt" read mode;
    variable line_number : integer := 0;
    variable line_data : signed(15 downto 0) := (others => '0');

    -- Signaux de débogage
    signal debug_image_data : signed(15 downto 0) := (others => '0');
    signal debug_pixel_window : signed(143 downto 0) := (others => '0');
    signal debug_kernel_constants : signed(143 downto 0) := (others => '0');

begin
    process
    begin
        wait for 10 ns;
        rst <= '0';

        -- Lire les pixels de l'image à partir du fichier
        while not endfile(image_file) loop
            readline(image_file, line_data);
            image_data <= line_data;
            debug_image_data <= line_data;
            wait for 10 ns;
        end loop;

        wait;
    end process;

    clk_process : process
    begin
        wait for 5 ns;
        clk <= '1';
        wait for 5 ns;
        clk <= '0';
    end process;

    windowing_module_instance : windowing_module
        port map (
            clk => clk,
            rst => rst,
            image_data => image_data,
            pixel_window => pixel_window,
            kernel_constants => kernel_constants
        );

    -- Affichage des signaux de débogage
    process(clk)
    begin
        if rising_edge(clk) then
            debug_pixel_window <= pixel_window;
            debug_kernel_constants <= kernel_constants;
        end if;
    end process;

    -- Affichage des signaux de débogage sur la console
    process
    begin
        wait for 10 ns;
        report "Image Data: " & to_string(debug_image_data);
        report "Pixel Window: " & to_string(debug_pixel_window);
        report "Kernel Constants: " & to_string(debug_kernel_constants);
    end process;
end architecture;