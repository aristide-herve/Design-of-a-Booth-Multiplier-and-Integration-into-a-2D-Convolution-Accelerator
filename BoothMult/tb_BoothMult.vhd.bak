library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity tb_BoothMult is
end entity;

architecture sim of tb_BoothMult is

    signal A, B : std_logic_vector(15 downto 0);
    signal PRODUCT : std_logic_vector(31 downto 0);

begin

    -- Instanciation du DUT
    DUT: entity work.BoothMult
        port map (
            A       => A,
            B       => B,
            PRODUCT => PRODUCT
        );

    -- Process de test simple
    process
    begin
        -- Test 1
        A <= std_logic_vector(to_signed(0,16));
        B <= std_logic_vector(to_signed(0,16));
        wait for 20 ns;

        -- Test 2
        A <= std_logic_vector(to_signed(5,16));
        B <= std_logic_vector(to_signed(3,16));
        wait for 20 ns;

        -- Test 3
        A <= std_logic_vector(to_signed(-7,16));
        B <= std_logic_vector(to_signed(4,16));
        wait for 20 ns;

        -- Test 4
        A <= std_logic_vector(to_signed(32767,16));
        B <= std_logic_vector(to_signed(2,16));
        wait for 20 ns;

        -- Test 5
        A <= std_logic_vector(to_signed(-32768,16));
        B <= std_logic_vector(to_signed(-1,16));
        wait for 20 ns;

        -- Test aléatoire simple
        A <= std_logic_vector(to_signed(1234,16));
        B <= std_logic_vector(to_signed(-5678,16));
        wait for 20 ns;

        -- Fin du testbench
        wait;
    end process;

end architecture;
