library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity top_conv3x3 is
    port (
        clk       : in  std_logic;
        rst       : in  std_logic;
        pixel_in  : in  std_logic_vector(15 downto 0); -- pixel signé
        pixel_out : out std_logic_vector(31 downto 0)  -- résultat convolution
    );
end entity;

architecture structural of top_conv3x3 is

    -- fenêtre 3x3 (9 pixels de 16 bits)
    signal pixel_win : std_logic_vector(9*16-1 downto 0);

    -- noyau (exemple : Sobel horizontal)
    constant k00 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed(-1,16));
    constant k01 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed( 0,16));
    constant k02 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed( 1,16));

    constant k10 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed(-2,16));
    constant k11 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed( 0,16));
    constant k12 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed( 2,16));

    constant k20 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed(-1,16));
    constant k21 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed( 0,16));
    constant k22 : std_logic_vector(15 downto 0) := std_logic_vector(to_signed( 1,16));

begin

    -- line buffer 3 lignes
    LB: entity line_buffer_3lines_simple
        port map(
            clk       => clk,
            rst       => rst,
            pixel_in  => pixel_in,
            pixel_win => pixel_win
        );

    -- convolution 3x3
    CONV: entity conv3x3_from_window
        port map(
            pixel_win => pixel_win,
            k00 => k00, k01 => k01, k02 => k02,
            k10 => k10, k11 => k11, k12 => k12,
            k20 => k20, k21 => k21, k22 => k22,
            Qout => pixel_out
        );

end architecture;
